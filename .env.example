# Supabase connection used by the forecasting dashboard on Vercel and locally.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional: set this if you still run the legacy Python forecasting backend.
# Leave blank to use Supabase-only data reads.
VITE_FORECAST_API_URL=http://127.0.0.1:5000/api
